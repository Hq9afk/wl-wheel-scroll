#!/usr/bin/env python3
"""
wl-wheel-scroll — circular rim scrolling daemon for Wayland touchpads.
Move your finger around the edge of the pad to scroll.
"""

import sys
import math
import time
import signal
import configparser
from pathlib import Path
import evdev
from evdev import InputDevice, UInput, ecodes as e

CONFIG_PATH = Path.home() / ".config" / "wl-wheel-scroll" / "config.ini"

_DEFAULTS = {
    "rim_threshold":    "0.75",
    "angle_per_tick":   "0.15",
    "scroll_speed":     "1",
    "touch_timeout":    "0.5",
    "horizontal_scroll": "false",
}

def _write_default_config():
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_PATH, "w") as f:
        f.write(
            "[scroll]\n"
            "# outer fraction of pad radius that triggers rim scrolling (0-1)\n"
            "rim_threshold = 0.75\n\n"
            "# radians of rotation per scroll tick — smaller = more sensitive\n"
            "angle_per_tick = 0.15\n\n"
            "# REL_WHEEL units per tick\n"
            "scroll_speed = 1\n\n"
            "# seconds before state resets if touch is lost\n"
            "touch_timeout = 0.5\n\n"
            "# true to scroll horizontally instead of vertically\n"
            "horizontal_scroll = false\n"
        )

def _load_config():
    if not CONFIG_PATH.exists():
        _write_default_config()
    cfg = configparser.ConfigParser()
    cfg["scroll"] = _DEFAULTS
    cfg.read(CONFIG_PATH)
    return cfg["scroll"]

_s = _load_config()
RIM_THRESHOLD     = _s.getfloat("rim_threshold")
ANGLE_PER_TICK    = _s.getfloat("angle_per_tick")
SCROLL_SPEED      = _s.getint("scroll_speed")
TOUCH_TIMEOUT     = _s.getfloat("touch_timeout")
HORIZONTAL_SCROLL = _s.getboolean("horizontal_scroll")

TOUCHPAD_KEYWORDS = ["synaptics"]

def find_touchpad():
    for path in evdev.list_devices():
        try:
            dev = InputDevice(path)
            name = dev.name.lower()
            caps = dev.capabilities()
            has_abs = e.EV_ABS in caps
            name_match = any(k in name for k in TOUCHPAD_KEYWORDS)
            # EV_ABS caps are (code, AbsInfo) tuples, not plain ints
            has_touch_axes = any(
                code in (e.ABS_X, e.ABS_MT_POSITION_X)
                for code, _ in caps.get(e.EV_ABS, [])
            )
            if has_abs and has_touch_axes and (name_match or "touchpad" in name):
                return dev
            dev.close()
        except (PermissionError, OSError):
            continue
    return None

def angle_diff(a, b):
    """Signed shortest angular distance in [-π, π]."""
    d = b - a
    while d > math.pi:  d -= 2 * math.pi
    while d < -math.pi: d += 2 * math.pi
    return d

def run(dev):
    caps = dev.capabilities()
    abs_info = dict(caps.get(e.EV_ABS, []))

    xi = abs_info.get(e.ABS_X) or abs_info.get(e.ABS_MT_POSITION_X)
    yi = abs_info.get(e.ABS_Y) or abs_info.get(e.ABS_MT_POSITION_Y)
    if xi is None or yi is None:
        print("ERROR: Could not read touchpad axis ranges.", file=sys.stderr)
        sys.exit(1)

    x_min, x_max = xi.min, xi.max
    y_min, y_max = yi.min, yi.max
    cx = (x_min + x_max) / 2
    cy = (y_min + y_max) / 2
    # smaller axis keeps the rim zone circular, not elliptical
    r_max = min((x_max - x_min) / 2, (y_max - y_min) / 2)

    print(f"Touchpad: {dev.name} ({dev.path})")
    print(f"  X range: {x_min}–{x_max}  Y range: {y_min}–{y_max}")
    print(f"  Centre: ({cx:.0f}, {cy:.0f})")
    print(f"  Config:  {CONFIG_PATH}")

    tp_caps = dict(caps)
    tp_caps.pop(e.EV_SYN, None)
    # input_props required so libinput classifies this as a touchpad
    tp_ui = UInput(tp_caps, name="wl-wheel-scroll-tp", version=0x1,
                   input_props=dev.input_props())

    # separate device so libinput doesn't ignore REL_WHEEL on a touchpad node
    scroll_ui = UInput(
        {e.EV_REL: [e.REL_WHEEL, e.REL_WHEEL_HI_RES, e.REL_HWHEEL, e.REL_HWHEEL_HI_RES]},
        name="wl-wheel-scroll",
    )

    print(f"  Touchpad virt: {tp_ui.device.path}")
    print(f"  Scroll virt:   {scroll_ui.device.path}")
    print("Running — Ctrl-C to stop.\n")

    tracking = False
    in_rim = False
    prev_angle = None
    accum = 0.0
    last_event_t = 0.0
    cur_x = cx
    cur_y = cy
    pending = []

    cfg_mtime = CONFIG_PATH.stat().st_mtime if CONFIG_PATH.exists() else 0.0
    rim_threshold     = RIM_THRESHOLD
    angle_per_tick    = ANGLE_PER_TICK
    scroll_speed      = SCROLL_SPEED
    touch_timeout     = TOUCH_TIMEOUT
    horizontal_scroll = HORIZONTAL_SCROLL
    rim_r = rim_threshold * r_max

    def reload_config():
        nonlocal cfg_mtime, rim_threshold, angle_per_tick, scroll_speed
        nonlocal touch_timeout, horizontal_scroll, rim_r
        try:
            mtime = CONFIG_PATH.stat().st_mtime
        except OSError:
            return
        if mtime <= cfg_mtime:
            return
        cfg_mtime = mtime
        s = _load_config()
        rim_threshold     = s.getfloat("rim_threshold")
        angle_per_tick    = s.getfloat("angle_per_tick")
        scroll_speed      = s.getint("scroll_speed")
        touch_timeout     = s.getfloat("touch_timeout")
        horizontal_scroll = s.getboolean("horizontal_scroll")
        rim_r = rim_threshold * r_max
        print(f"Config reloaded: rim={rim_threshold} tick={angle_per_tick} "
              f"speed={scroll_speed} timeout={touch_timeout} horiz={horizontal_scroll}")

    def reset():
        nonlocal tracking, in_rim, prev_angle, accum
        tracking = False
        in_rim = False
        prev_angle = None
        accum = 0.0

    def flush_scroll():
        nonlocal accum
        ticks = int(accum / angle_per_tick)
        if ticks == 0:
            return
        accum -= ticks * angle_per_tick
        axis    = e.REL_HWHEEL        if horizontal_scroll else e.REL_WHEEL
        axis_hi = e.REL_HWHEEL_HI_RES if horizontal_scroll else e.REL_WHEEL_HI_RES
        scroll_ui.write(e.EV_REL, axis,    ticks * scroll_speed)
        scroll_ui.write(e.EV_REL, axis_hi, ticks * scroll_speed * 120)
        scroll_ui.syn()

    def forward_pending():
        for ev in pending:
            tp_ui.write(ev.type, ev.code, ev.value)
        tp_ui.syn()
        pending.clear()

    try:
        for event in dev.read_loop():
            now = time.monotonic()

            reload_config()

            if tracking and (now - last_event_t) > touch_timeout:
                reset()

            t = event.type
            c = event.code
            v = event.value

            if t == e.EV_ABS:
                last_event_t = now
                if c in (e.ABS_X, e.ABS_MT_POSITION_X):
                    cur_x = v
                elif c in (e.ABS_Y, e.ABS_MT_POSITION_Y):
                    cur_y = v
                pending.append(event)

            elif t == e.EV_KEY:
                if c == e.BTN_TOUCH:
                    if v == 1:
                        tracking = True
                        last_event_t = now
                        prev_angle = None
                        accum = 0.0
                        in_rim = False
                    else:
                        flush_scroll()
                        reset()
                pending.append(event)

            elif t == e.EV_SYN and c == e.SYN_REPORT:
                if tracking:
                    dx = cur_x - cx
                    dy = cur_y - cy
                    r = math.hypot(dx, dy)
                    currently_in_rim = r >= rim_r

                    if currently_in_rim:
                        angle = math.atan2(dy, dx)
                        if not in_rim:
                            prev_angle = angle
                            in_rim = True
                        else:
                            if prev_angle is not None:
                                accum -= angle_diff(prev_angle, angle)
                                flush_scroll()
                            prev_angle = angle
                        # drop position coords but keep slot/tracking-ID/pressure
                        # so libinput's MT state stays intact
                        pos_codes = {e.ABS_X, e.ABS_Y,
                                     e.ABS_MT_POSITION_X, e.ABS_MT_POSITION_Y}
                        passthrough = [ev for ev in pending
                                       if not (ev.type == e.EV_ABS
                                               and ev.code in pos_codes)]
                        pending.clear()
                        if passthrough:
                            for ev in passthrough:
                                tp_ui.write(ev.type, ev.code, ev.value)
                            tp_ui.syn()
                    else:
                        if in_rim:
                            flush_scroll()
                            prev_angle = None
                            accum = 0.0
                        in_rim = False
                        forward_pending()
                else:
                    forward_pending()

            else:
                pending.append(event)

    finally:
        tp_ui.close()
        scroll_ui.close()


def main():
    if len(sys.argv) > 1:
        path = sys.argv[1]
        try:
            dev = InputDevice(path)
        except (FileNotFoundError, PermissionError) as ex:
            print(f"Cannot open {path}: {ex}", file=sys.stderr)
            sys.exit(1)
    else:
        dev = find_touchpad()
        if dev is None:
            print(
                "Could not auto-detect touchpad.\n"
                "Run:  libinput list-devices\n"
                "Then: wl-wheel-scroll /dev/input/eventX",
                file=sys.stderr,
            )
            sys.exit(1)

    dev.grab()  # exclusive grab — libinput sees only the virtual devices

    def _exit(sig, frame):
        print("\nShutting down.")
        try:
            dev.ungrab()
        except Exception:
            pass
        dev.close()
        sys.exit(0)

    signal.signal(signal.SIGINT, _exit)
    signal.signal(signal.SIGTERM, _exit)

    run(dev)


if __name__ == "__main__":
    main()
